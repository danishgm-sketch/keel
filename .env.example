# Copy this file to `.env` and fill in your own Alpaca keys.
# `.env` is gitignored and must NEVER be committed. This example is safe to share.
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# Get keys at https://app.alpaca.markets  ->  paper or live, "API Keys".
# Market-data access only is needed for `keel fetch`; no trading permission required.

ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
